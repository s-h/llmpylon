{
  "name": "llmpylon",
  "version": "1.5.0",
  "description": "llmPylon — self-hosted LLM API proxy with admin UI, multi-provider routing, and usage stats (SQLite).",
  "main": "index.js",
  "scripts": {
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "keywords": [
    "llm",
    "proxy",
    "openai",
    "anthropic",
    "sqlite"
  ],
  "author": "",
  "license": "AGPL-3.0-only",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.13.6",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "knex": "^3.2.5",
    "picomatch": "^4.0.4",
    "socket.io": "^4.8.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
